model {
  # Likelihood
  for (i in 1:N) {
    z[i] ~ dnorm(mu[i], tau)
    mu[i] <- alpha + beta * grid[i]
    classification[i] ~ dinterval(z[i], cutoff[])
  }

  # Priors
  alpha ~ dnorm(0, 0.001)
  beta  ~ dnorm(0, 0.001)

  sigma ~ dunif(0, 10)
  tau <- 1 / sigma^2


  cutoff[1] ~ dnorm(0, 0.01)
  for (k in 2:(K-1)) {
    cutoff[k] ~ dnorm(cutoff[k-1], 1) T(cutoff[k-1], )
  }
}